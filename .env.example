# mlx-auto-lora environment variables
# Copy to .env (gitignored) and edit. Loaded by bin/lab.sh and the listener installer.

# ── Lab root ──────────────────────────────────────────────────────────────────
# Where the lab lives on disk. Defaults to $HOME/mlx-auto-lora if unset.
# MLX_AUTO_LORA_ROOT=$HOME/mlx-auto-lora

# ── LLM judge (optional) ──────────────────────────────────────────────────────
# Anthropic Claude is used as the idiomaticity judge if this is set.
# Without it, the judge component is recorded null and the composite is
# renormalized over compile + lint.
# ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram notifier (optional) ──────────────────────────────────────────────
# If TELEGRAM_BOT_TOKEN is unset, the StdoutNotifier prints instead. Useful
# for first-run smoke testing or anyone who doesn't want a bot.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=-1001234567890
# TELEGRAM_THREAD_ID=42        # optional; omit to post to the chat root
